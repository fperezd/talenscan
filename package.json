{
  "name": "talenscan",
  "private": true,
  "workspaces": ["apps/web", "apps/api"],
  "scripts": {
    "dev:web": "npm run dev -w @talenscan/web",
    "build:web": "npm run build -w @talenscan/web",
    "deploy:web:cf": "wrangler deploy -c wrangler.worker.jsonc",
    "dev:api": "uvicorn app.main:app --reload --port 8000 --app-dir apps/api",
    "health": "curl http://127.0.0.1:8000/health"
  }
}
