DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/talenscan
MAX_UPLOAD_SIZE_MB=12
STORAGE_BASE_URL=local://candidate-documents

# OpenAI — usar gpt-4o-mini para perfil objetivo y parseo de CV.
# Si OPENAI_API_KEY está vacía, los módulos IA usan fallback determinista.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=45
OPENAI_MAX_RETRIES=1
