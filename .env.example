NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
API_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/talenscan
MAX_UPLOAD_SIZE_MB=12
STORAGE_BASE_URL=local://candidate-documents

# OpenAI — usar en apps/api/.env (nunca en frontend).
# Si está vacía, los módulos IA usan fallback determinista.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=45
OPENAI_MAX_RETRIES=1
